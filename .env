PORT=8081
MONGODB_URI=mongodb+srv://kirubabotamation:20302022@cluster0.vbk6r.mongodb.net/leadApp?retryWrites=true&w=majority
NODE_ENV=development

# ── SSO Core ──────────────────────────────────────────────────
# MUST match the JWT_SECRET used by the auth service exactly
JWT_SECRET=localsecretkey
JWT_REFRESH_SECRET=localrefreshsecretkey

# URL of the centralised auth service (backend API)
AUTH_SERVICE_URL=http://localhost:8080

# URL of the auth service frontend (login page)
AUTH_FRONTEND_URL=http://localhost:3000

# Base URL of this application's frontend
FRONTEND_BASE_URL=http://localhost:3001

# Cookie domain — shared across all apps in the same domain
# Local:       localhost
# Production:  .botamation.in  (leading dot = all subdomains)
COOKIE_DOMAIN=localhost

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of all allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:3000,http://localhost:8080

# ── Local Dev Skip (optional) ─────────────────────────────────
# Set to true to bypass SSO entirely during local development
SKIP_LOGIN=false
SKIP_LOGIN_USER_ID=dev-user-001
SKIP_LOGIN_USER_EMAIL=dev@botamation.in
SKIP_LOGIN_USER_NAME=Dev User
SKIP_LOGIN_USER_GOOGLE_EMAIL=dev@gmail.com
SKIP_LOGIN_USER_PROFILE_IMAGE=

# ── Mock Auth (legacy dev helper) ─────────────────────────────
USE_MOCK_AUTH=false
